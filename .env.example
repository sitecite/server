# Hey there! Here's the .env file, used to store secrets and some simple config!
# This file is used for all the secrets. For basic config, please check out the config.yaml file.

# * Configure MySQL
# ! Do not forget to change this!
# Port for MySQL database
MYSQL_PORT = 3306
# Host (e.g. "localhost")
MYSQL_HOST = "localhost"
# Username
MYSQL_USER = ""
# Password
MYSQL_PASSWORD = ""
# You can leave the database as-is, but you can change it if you want to. Do not leave it empty though!
MYSQL_DATABASE = "sitecite"

# * Configure Discord OAuth2
# It's optional, as long as a user has an alternative. In selfhosted, private use settings, I'd recommend against OAuth.
# You can get the credentials you need from discord.com/developers/applications

# Your application ID
DISCORD_ID = ""
# Your client secret
DISCORD_SECRET = ""
# The redirect URL set in Discord. It should be something like: https://example.com/account/discord
DISCORD_URL = ""
# The URL to redirect users to in order to authenticate; this is a link to Discord.
DISCORD_AUTH_URL = ""

# * Configure Google OAuth 2
# Just like Discord, this is also optional. Similarly, I'd recommend against OAuth if it's just for you and your friends.
# You can get the values you need from console.cloud.google.com

# Your client ID
GOOGLE_ID = ""
# Your client secret
GOOGLE_SECRET = ""
# The redirect URL set in Google. It should look something like: https://example.com/account/google
GOOGLE_URL = ""
# There is no AUTH_URL as this is constructed automatically for the following scope(s):
# - openid

# * abuse.ch key
# If you want to, you can scan the URLs that are opened with URLhaus. This checks URLs for things as malware. If you trust your friends, you don't need this. 
# If you plan on opening your server for everyone to use, this may be something to consider.
# For more info: https://urlhaus-api.abuse.ch/
ABUSE_CH_KEY = ""

# * Cookie secret
# ! IT IS NOT RECOMMENDED TO CHANGE THIS! DO NOT USE IN PRODUCTION!
# If you are developing sitecite, it can be inconvenient to have to sign in again every time you restart the server.
# This can be prevented by having a single set cookie secret.
COOKIE_SECRET = ""